{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AgentQueryRequest",
  "type": "object",
  "properties": {
    "query_type": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]+$",
      "maxLength": 32
    },
    "resource_id": {
      "type": "string",
      "pattern": "^[a-zA-Z0-9_-]+$",
      "maxLength": 64
    }
  },
  "required": ["query_type", "resource_id"],
  "additionalProperties": false
}
