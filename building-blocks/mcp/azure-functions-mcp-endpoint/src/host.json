{
  "version": "2.0",
  "extensionBundle": {
    "id": "Microsoft.Azure.Functions.ExtensionBundle",
    "version": "[4.0.0, 5.0.0)"
  },
  "extensions": {
    "mcp": {
      "serverName": "ReferenceMcpServer",
      "serverVersion": "1.0.0",
      "instructions": "This server provides a reference MCP tool 'get_synthetic_resource' for retrieving synthetic resource metadata. It is a safe, read-only endpoint."
    }
  },
  "logging": {
    "applicationInsights": {
      "samplingSettings": {
        "isEnabled": true,
        "excludedTypes": "Request"
      }
    }
  }
}
