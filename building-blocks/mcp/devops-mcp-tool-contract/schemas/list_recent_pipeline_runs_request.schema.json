{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/wildersa/azure_ref_kit/building-blocks/mcp/devops-mcp-tool-contract/schemas/list_recent_pipeline_runs_request.schema.json",
  "title": "ListRecentPipelineRunsRequest",
  "type": "object",
  "required": [
    "pipeline_id"
  ],
  "properties": {
    "pipeline_id": {
      "type": "string",
      "description": "The ID or name of the pipeline.",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-zA-Z0-9_\\-\\.\\ ]+$"
    },
    "top": {
      "type": "integer",
      "description": "Number of recent runs to return (default: 5, max: 20).",
      "minimum": 1,
      "maximum": 20,
      "default": 5
    }
  },
  "additionalProperties": false
}
