{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/wildersa/azure_ref_kit/building-blocks/mcp/devops-mcp-tool-contract/schemas/list_recent_pipeline_runs_response.schema.json",
  "title": "ListRecentPipelineRunsResponse",
  "type": "object",
  "required": [
    "pipeline_name",
    "runs"
  ],
  "properties": {
    "pipeline_name": {
      "type": "string",
      "description": "The name of the Azure DevOps pipeline."
    },
    "runs": {
      "type": "array",
      "description": "List of recent runs.",
      "items": {
        "type": "object",
        "required": [
          "run_id",
          "status",
          "result",
          "branch",
          "start_time"
        ],
        "properties": {
          "run_id": {
            "type": "string",
            "description": "The unique identifier for the specific run."
          },
          "status": {
            "type": "string",
            "enum": [
              "inProgress",
              "completed",
              "queued",
              "cancelling",
              "postponed",
              "notStarted"
            ],
            "description": "The current state of the run."
          },
          "result": {
            "type": "string",
            "enum": [
              "succeeded",
              "failed",
              "canceled",
              "partiallySucceeded",
              "none"
            ],
            "description": "The outcome of a completed run."
          },
          "branch": {
            "type": "string",
            "description": "The source branch for the run."
          },
          "start_time": {
            "type": "string",
            "format": "date-time",
            "description": "When the run started."
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
