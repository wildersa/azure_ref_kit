{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SystemStatusResponse",
  "type": "object",
  "properties": {
    "business_status": {
      "type": "string",
      "description": "Friendly operational status."
    },
    "service_health": {
      "type": "string",
      "description": "Technical health indicator."
    },
    "active_regions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of regions currently serving traffic."
    },
    "last_updated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 timestamp of the last status update."
    },
    "environment": {
      "type": "string",
      "description": "Name of the environment."
    }
  },
  "required": [
    "business_status",
    "service_health",
    "active_regions",
    "last_updated",
    "environment"
  ],
  "additionalProperties": false
}
