  "properties": {
    "error": { "type": "string", "maxLength": 128 },
    "status": { "type": "string", "const": "failed", "maxLength": 64 },
    "friendly_message": { "type": "string", "maxLength": 2048 }
  },
  "additionalProperties": false
}
