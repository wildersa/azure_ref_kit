{
  "tools": [
    {
      "name": "get_pipeline_status",
      "description": "Get the high-level business status and summary of a pipeline run.",
      "parameters": {
        "type": "object",
        "properties": {
          "run_id": {
            "type": "string",
            "description": "The unique identifier of the pipeline run."
          }
        },
        "required": ["run_id"]
      },
      "response": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["pending", "running", "waiting_input", "failed", "completed", "cancelled"] },
          "progress_percent": { "type": "integer" },
          "business_summary": { "type": "string" },
          "estimated_cost": { "type": "number" },
          "created_at": { "type": "string", "format": "date-time" },
          "started_at": { "type": "string", "format": "date-time" },
          "finished_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    {
      "name": "get_pipeline_steps",
      "description": "Get the detailed timeline and status of individual steps in a pipeline run.",
      "parameters": {
        "type": "object",
        "properties": {
          "run_id": {
            "type": "string",
            "description": "The unique identifier of the pipeline run."
          }
        },
        "required": ["run_id"]
      },
      "response": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "status": { "type": "string" },
            "input_summary": { "type": "string" },
            "output_summary": { "type": "string" },
            "started_at": { "type": "string", "format": "date-time" },
            "finished_at": { "type": "string", "format": "date-time" }
          }
        }
      }
    },
    {
      "name": "get_artifacts",
      "description": "Get a list of customer-visible artifacts (documents, results) generated by the pipeline run.",
      "parameters": {
        "type": "object",
        "properties": {
          "run_id": {
            "type": "string",
            "description": "The unique identifier of the pipeline run."
          }
        },
        "required": ["run_id"]
      },
      "response": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "safe_name": { "type": "string" },
            "kind": { "type": "string" },
            "size_bytes": { "type": "integer" },
            "created_at": { "type": "string", "format": "date-time" }
          }
        }
      }
    },
    {
      "name": "explain_error",
      "description": "Get a friendly, non-technical explanation of why a pipeline run failed.",
      "parameters": {
        "type": "object",
        "properties": {
          "run_id": {
            "type": "string",
            "description": "The unique identifier of the pipeline run."
          }
        },
        "required": ["run_id"]
      },
      "response": {
        "type": "object",
        "properties": {
          "friendly_error": { "type": "string" }
        }
      }
    },
    {
      "name": "estimate_cost",
      "description": "Get the estimated total cost of a pipeline run.",
      "parameters": {
        "type": "object",
        "properties": {
          "run_id": {
            "type": "string",
            "description": "The unique identifier of the pipeline run."
          }
        },
        "required": ["run_id"]
      },
      "response": {
        "type": "object",
        "properties": {
          "estimated_amount": { "type": "number" },
          "currency": { "type": "string" }
        }
      }
    },
    {
      "name": "request_human_review",
      "description": "Request a human expert to review the pipeline run or specific results.",
      "parameters": {
        "type": "object",
        "properties": {
          "run_id": {
            "type": "string",
            "description": "The unique identifier of the pipeline run."
          },
          "reason": {
            "type": "string",
            "description": "The reason why a human review is being requested."
          }
        },
        "required": ["run_id", "reason"]
      },
      "response": {
        "type": "object",
        "properties": {
          "review_id": { "type": "string" },
          "status": { "type": "string" }
        }
      }
    }
  ]
}
