{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/wildersa/azure_ref_kit/shared/contracts/devops-status.schema.json",
  "title": "DevOpsStatus",
  "type": "object",
  "required": [
    "pipeline_name",
    "run_id",
    "status",
    "result",
    "branch",
    "start_time"
  ],
  "properties": {
    "pipeline_name": {
      "type": "string",
      "description": "The name of the Azure DevOps pipeline.",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-zA-Z0-9_\\-\\.\\ ]+$"
    },
    "run_id": {
      "type": "string",
      "description": "The unique identifier for the specific run or build.",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-zA-Z0-9_\\-\\.\\ ]+$"
    },
    "status": {
      "type": "string",
      "enum": [
        "inProgress",
        "completed",
        "queued",
        "cancelling",
        "postponed",
        "notStarted"
      ],
      "description": "The current state of the run."
    },
    "result": {
      "type": "string",
      "enum": [
        "succeeded",
        "failed",
        "canceled",
        "partiallySucceeded",
        "none"
      ],
      "description": "The outcome of a completed run."
    },
    "branch": {
      "type": "string",
      "description": "The source branch for the run.",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-zA-Z0-9_\\-\\.\\ ]+$"
    },
    "commit_sha": {
      "type": "string",
      "description": "The short commit SHA associated with the run.",
      "minLength": 7,
      "maxLength": 8,
      "pattern": "^[a-fA-F0-9]{7,8}$"
    },
    "start_time": {
      "type": "string",
      "format": "date-time",
      "description": "When the run started."
    },
    "end_time": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time",
      "description": "When the run finished."
    },
    "duration_seconds": {
      "type": [
        "integer",
        "null"
      ],
      "description": "The total duration of the run in seconds.",
      "minimum": 0,
      "maximum": 864000
    },
    "summary": {
      "type": "string",
      "description": "A friendly business-level summary of the run status or failure.",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[a-zA-Z0-9_\\-\\.\\ \\(\\)\\',;!]+$"
    }
  },
  "additionalProperties": false
}
