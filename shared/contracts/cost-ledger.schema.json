{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/wildersa/azure_ref_kit/shared/contracts/cost-ledger.schema.json",
  "title": "CostLedgerEntry",
  "type": "object",
  "required": ["run_id", "category", "estimated_amount"],
  "properties": {
    "run_id": { "type": "string" },
    "step_name": { "type": ["string", "null"] },
    "category": {
      "type": "string",
      "enum": ["ai_tokens", "document_ai", "storage", "function_execution", "integration", "other"]
    },
    "provider": { "type": ["string", "null"] },
    "model_or_service": { "type": ["string", "null"] },
    "input_units": { "type": ["number", "null"] },
    "output_units": { "type": ["number", "null"] },
    "unit_name": { "type": ["string", "null"] },
    "estimated_amount": { "type": "number" },
    "currency": { "type": "string", "default": "USD" },
    "created_at": { "type": ["string", "null"], "format": "date-time" }
  },
  "additionalProperties": false
}
