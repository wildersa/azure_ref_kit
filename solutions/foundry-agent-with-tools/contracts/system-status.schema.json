{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/wildersa/azure_ref_kit/solutions/foundry-agent-with-tools/contracts/system-status.schema.json",
  "title": "SystemStatus",
  "type": "object",
  "required": [
    "business_status",
    "service_health",
    "active_regions",
    "last_updated",
    "environment"
  ],
  "properties": {
    "business_status": {
      "type": "string",
      "description": "Friendly operational status (e.g., 'operational')."
    },
    "service_health": {
      "type": "string",
      "description": "Technical health indicator."
    },
    "active_regions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of regions currently serving traffic."
    },
    "last_updated": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 timestamp of the last status update."
    },
    "environment": {
      "type": "string",
      "description": "Name of the environment (e.g., 'prod', 'staging')."
    }
  },
  "additionalProperties": false
}
